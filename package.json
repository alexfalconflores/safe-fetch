{
  "name": "@alexfalconflores/safe-fetch",
  "version": "2.0.2",
  "description": "The production-ready, typed HTTP client with built-in retries, timeouts, interceptors, and cancellation.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexfalconflores/safe-fetch.git"
  },
  "bugs": {
    "url": "https://github.com/alexfalconflores/safe-fetch/issues"
  },
  "homepage": "https://github.com/alexfalconflores/safe-fetch#readme",
  "keywords": [
    "fetch",
    "http",
    "typescript",
    "api",
    "http-client",
    "retries",
    "timeout",
    "interceptors",
    "abort-controller",
    "cancellation",
    "request-wrapper"
  ],
  "author": "Alex Stefano Falcon Flores",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --watch --dts",
    "clean": "rm -rf dist",
    "test": "bun test",
    "push": "bun run build && yalc add",
    "prepublishOnly": "bun run clean && bun run build",
    "release": "bun publish --access public"
  },
  "devDependencies": {
    "tsup": "8.4.0",
    "typescript": "5.8.3",
    "@types/bun": "latest",
    "@types/node": "25.2.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
